// ==UserScript==
// @name         Kinozal.tv to Torrent Upload
// @namespace    http://tampermonkey.net/
// @version      1.07
// @description  Заменяет текст на гиперссылку для отправки торрент-файла на локальный сервер
// @author       Chuvakstepan, DeepSeek
// @match        https://kinozal.tv/details.php?id=*
// @grant        GM_xmlhttpRequest
// @grant        GM_download
// @connect      192.168.1.133
// @connect      dl.kinozal.tv
// @connect      kinozal.tv
// @connect      i4.imageban.ru
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    console.log('=== Скрипт Kinozal.tv Uploader запущен ===');

    // Функция для получения ID раздачи из URL
    function getTorrentId() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('id');
    }

    // Функция для получения заголовка раздачи
    function getTorrentTitle() {
        const ogTitle = document.querySelector('meta[property="og:title"]');
        if (ogTitle) {
            const title = ogTitle.getAttribute('content');
            if (title) {
                console.log('✅ Title из og:title:', title);
                return title;
            }
        }

        const productName = document.querySelector('[itemprop="name"]');
        if (productName) {
            const title = productName.getAttribute('content');
            if (title) {
                console.log('✅ Title из schema.org Product:', title);
                return title;
            }
        }

        const h1Title = document.querySelector('h1 a.r1, h1 a.r0');
        if (h1Title) {
            const title = h1Title.textContent.trim();
            if (title) {
                console.log('✅ Title из h1:', title);
                return title;
            }
        }

        const pageTitle = document.querySelector('title');
        if (pageTitle) {
            let title = pageTitle.textContent.trim();
            title = title.replace(/:: Кинозал\.ТВ$/, '').trim();
            if (title) {
                console.log('✅ Title из title страницы:', title);
                return title;
            }
        }

        console.log('❌ Title не найден');
        return '';
    }

    // Функция для получения URL постера
    function getPosterUrl() {
        const ogImage = document.querySelector('meta[property="og:image"]');
        if (ogImage) {
            let url = ogImage.getAttribute('content');
            if (url) {
                if (url.startsWith('/')) {
                    url = 'https://kinozal.tv' + url;
                    console.log('✅ Постер из og:image (относительный):', url);
                    return url;
                }
                if (url.startsWith('http')) {
                    console.log('✅ Постер из og:image (абсолютный):', url);
                    return url;
                }
            }
        }

        const menuImage = document.querySelector('.mn1_menu .p200');
        if (menuImage) {
            let src = menuImage.src;
            if (src) {
                if (src.startsWith('/')) {
                    src = 'https://kinozal.tv' + src;
                    console.log('✅ Постер из меню (относительный):', src);
                    return src;
                }
                if (src.startsWith('http')) {
                    console.log('✅ Постер из меню (абсолютный):', src);
                    return src;
                }
            }
        }

        const posterImg = document.querySelector('img[src*="/i/poster/"]');
        if (posterImg) {
            let src = posterImg.src;
            if (src) {
                if (src.startsWith('/')) {
                    src = 'https://kinozal.tv' + src;
                    console.log('✅ Постер найден по пути /i/poster/:', src);
                    return src;
                }
                if (src.startsWith('http')) {
                    console.log('✅ Постер найден по пути /i/poster/ (абсолютный):', src);
                    return src;
                }
            }
        }

        console.log('❌ Постер не найден');
        return '';
    }

    // Функция для получения URL скачивания торрента
    function getDownloadUrl() {
        const downloadLink = document.querySelector('a[href*="dl.kinozal.tv/download.php"]');
        if (downloadLink) {
            return downloadLink.href;
        }
        return null;
    }

    // Функция для скачивания торрента через GM_xmlhttpRequest
    function downloadTorrentGM(url) {
        return new Promise((resolve, reject) => {
            console.log('📥 Скачивание торрента с URL:', url);

            GM_xmlhttpRequest({
                method: 'GET',
                url: url,
                responseType: 'blob',
                onload: function(response) {
                    console.log('📥 Ответ получен, статус:', response.status);
                    if (response.status === 200) {
                        console.log('📥 Торрент скачан, размер:', response.response.size, 'байт');
                        resolve(response.response);
                    } else {
                        reject(new Error(`HTTP ${response.status}: ${response.statusText}`));
                    }
                },
                onerror: function(error) {
                    console.error('❌ Ошибка при скачивании торрента:', error);
                    reject(new Error('Ошибка сети при скачивании торрента'));
                },
                ontimeout: function() {
                    reject(new Error('Таймаут при скачивании торрента'));
                },
                timeout: 30000
            });
        });
    }

    // Функция для отправки торрента на сервер
    function uploadTorrent(blob, torrentName, title, posterUrl) {
        return new Promise((resolve, reject) => {
            const formData = new FormData();
            formData.append('file', blob, torrentName);
            formData.append('save', 'true');
            if (title) {
                formData.append('title', title);
            }
            if (posterUrl) {
                formData.append('poster', posterUrl);
            }

            console.log('📤 ОТПРАВКА ЗАПРОСА:');
            console.log('📤 URL:', 'http://192.168.1.133:8090/torrent/upload');
            console.log('📤 Метод: POST');
            console.log('📤 Параметры формы:');
            console.log('  file:', torrentName, `(${blob.size} байт)`);
            console.log('  save: true');
            console.log('  title:', title || '(пусто)');
            console.log('  poster:', posterUrl || '(пусто)');

            GM_xmlhttpRequest({
                method: 'POST',
                url: 'http://192.168.1.133:8090/torrent/upload',
                headers: {
                    'Accept': 'application/json'
                },
                data: formData,
                onload: function(response) {
                    console.log('📥 ОТВЕТ СЕРВЕРА:');
                    console.log('📥 Статус:', response.status);
                    console.log('📥 Тело ответа:', response.responseText);

                    if (response.status === 200 || response.status === 201) {
                        try {
                            const jsonResponse = JSON.parse(response.responseText);
                            console.log('✅ Ответ сервера (JSON):', jsonResponse);
                            resolve(jsonResponse);
                        } catch (e) {
                            console.log('✅ Ответ сервера (текст):', response.responseText);
                            resolve(response.responseText);
                        }
                    } else {
                        reject(new Error(`HTTP ${response.status}: ${response.statusText}`));
                    }
                },
                onerror: function(error) {
                    console.error('❌ Ошибка отправки на сервер:', error);
                    reject(new Error('Ошибка сети при отправке на сервер'));
                },
                ontimeout: function() {
                    reject(new Error('Таймаут при отправке на сервер'));
                },
                timeout: 30000
            });
        });
    }

    // Основная функция
    function replaceTextWithLink() {
        console.log('🔍 Поиск td с кнопкой скачивания...');

        // Ищем td с ссылкой на скачивание
        const downloadTd = document.querySelector('td.nw a[href*="dl.kinozal.tv/download.php"]');
        if (!downloadTd) {
            console.log('❌ TD с кнопкой скачивания не найден');
            return;
        }

        // Находим родительский td
        const parentTd = downloadTd.closest('td.nw');
        if (!parentTd) {
            console.log('❌ Родительский td не найден');
            return;
        }

        console.log('✅ Найден td с кнопкой скачивания');

        // Ищем следующий td (с текстом)
        const nextTd = parentTd.nextElementSibling;
        if (!nextTd || nextTd.tagName !== 'TD') {
            console.log('❌ Следующий td не найден');
            return;
        }

        console.log('✅ Найден следующий td с текстом');

        if (document.getElementById('torrent-upload-link-container')) {
            console.log('⚠️ Ссылка уже существует');
            return;
        }

        const torrentId = getTorrentId();
        const torrentTitle = getTorrentTitle();
        const posterUrl = getPosterUrl();
        const downloadUrl = getDownloadUrl();

        console.log('📋 Данные раздачи:');
        console.log('  ID:', torrentId);
        console.log('  Title:', torrentTitle || '(пусто)');
        console.log('  Poster URL:', posterUrl || '(пусто)');
        console.log('  Download URL:', downloadUrl);

        if (!torrentId || !downloadUrl) {
            console.log('❌ Не удалось получить ID раздачи или URL скачивания');
            return;
        }

        // Очищаем ячейку
        nextTd.innerHTML = '';

        // Создаем контейнер с flex для расположения в строку
        const linkContainer = document.createElement('div');
        linkContainer.id = 'torrent-upload-link-container';
        linkContainer.style.cssText = `
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
            padding: 2px 0;
            flex-wrap: wrap;
        `;

        // Создаем уменьшенную гиперссылку
        const uploadLink = document.createElement('a');
        uploadLink.id = 'torrent-upload-link';
        uploadLink.href = '#';
        uploadLink.style.cssText = `
            display: inline-block;
            color: #0066cc;
            font-size: 13px;
            font-weight: 700;
            text-decoration: underline;
            cursor: pointer;
            padding: 3px 10px;
            transition: all 0.2s ease;
            background: #f0f8ff;
            border-radius: 3px;
            border: 1px solid #b8d4f0;
            white-space: nowrap;
            line-height: 20px;
        `;
        uploadLink.textContent = '📤 Отправить на сервер';

        // Ховер эффект
        uploadLink.onmouseover = function() {
            this.style.color = '#ff6b00';
            this.style.background = '#fff0e6';
            this.style.borderColor = '#ff6b00';
        };
        uploadLink.onmouseout = function() {
            this.style.color = '#0066cc';
            this.style.background = '#f0f8ff';
            this.style.borderColor = '#b8d4f0';
        };

        // Создаем элемент для статуса (маленький, справа)
        const statusDiv = document.createElement('div');
        statusDiv.id = 'torrent-upload-status-link';
        statusDiv.style.cssText = `
            font-size: 12px;
            color: #333;
            display: none;
            padding: 2px 8px;
            border-radius: 3px;
            background: #f8f9fa;
            border: 1px solid #ddd;
            white-space: nowrap;
            line-height: 20px;
            transition: all 0.3s ease;
        `;

        linkContainer.appendChild(uploadLink);
        linkContainer.appendChild(statusDiv);
        nextTd.appendChild(linkContainer);

        console.log('✅ Текст заменен на гиперссылку');

        // Обработчик клика
        uploadLink.addEventListener('click', async function(e) {
            e.preventDefault();

            const statusDiv = document.getElementById('torrent-upload-status-link');
            statusDiv.style.display = 'inline-block';
            statusDiv.innerHTML = '⏳ Скачивание...';
            statusDiv.style.background = '#fff3cd';
            statusDiv.style.borderColor = '#ffc107';

            uploadLink.textContent = '⏳ Загрузка...';
            uploadLink.style.cursor = 'wait';
            uploadLink.onmouseover = null;
            uploadLink.onmouseout = null;

            try {
                const blob = await downloadTorrentGM(downloadUrl);
                console.log('✅ Торрент успешно скачан, размер:', blob.size);

                statusDiv.innerHTML = '⏳ Отправка...';
                statusDiv.style.background = '#cce5ff';
                statusDiv.style.borderColor = '#b8daff';

                const torrentName = `[kinozal.tv]id${torrentId}.torrent`;

                const result = await uploadTorrent(blob, torrentName, torrentTitle, posterUrl);

                statusDiv.innerHTML = '✅ Отправлен!';
                statusDiv.style.background = '#d4edda';
                statusDiv.style.borderColor = '#c3e6cb';
                statusDiv.style.color = 'green';

                console.log('✅ Торрент успешно отправлен!', result);

            } catch (error) {
                console.error('❌ Ошибка:', error);
                statusDiv.innerHTML = '❌ Ошибка';
                statusDiv.style.background = '#f8d7da';
                statusDiv.style.borderColor = '#f5c6cb';
                statusDiv.style.color = 'red';
                statusDiv.title = error.message || 'Неизвестная ошибка';
            } finally {
                uploadLink.textContent = '📤 Отправить на сервер';
                uploadLink.style.cursor = 'pointer';
                uploadLink.onmouseover = function() {
                    this.style.color = '#ff6b00';
                    this.style.background = '#fff0e6';
                    this.style.borderColor = '#ff6b00';
                };
                uploadLink.onmouseout = function() {
                    this.style.color = '#0066cc';
                    this.style.background = '#f0f8ff';
                    this.style.borderColor = '#b8d4f0';
                };

                setTimeout(() => {
                    statusDiv.style.opacity = '0';
                    setTimeout(() => {
                        statusDiv.style.display = 'none';
                        statusDiv.style.opacity = '1';
                    }, 300);
                }, 3000);
            }
        });
    }

    // Инициализация
    function init() {
        console.log('🚀 Инициализация скрипта...');
        setTimeout(replaceTextWithLink, 1500);
        setTimeout(replaceTextWithLink, 3000);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    // Наблюдатель за изменениями
    const observer = new MutationObserver(function(mutations) {
        if (!document.getElementById('torrent-upload-link-container')) {
            console.log('🔄 Ссылка не найдена, пробуем добавить...');
            replaceTextWithLink();
        }
    });
    observer.observe(document.body, { childList: true, subtree: true });

})();
