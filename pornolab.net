// ==UserScript==
// @name         Pornolab.net to Transmission Upload
// @namespace    http://tampermonkey.net/
// @version      2.6
// @description  Добавляет кнопку для отправки торрент-файла в Transmission и управления торрентами
// @author       Chuvakstepan, DeepSeek
// @match        https://pornolab.net/forum/viewtopic.php?t=*
// @grant        GM_xmlhttpRequest
// @grant        GM_download
// @grant        GM_registerMenuCommand
// @connect      192.168.1.73
// @connect      pornolab.net
// @connect      static.pornolab.net
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    // Проверяем, не запущен ли уже скрипт
    if (window._pornolab_transmission_loaded) {
        console.log('⚠️ Скрипт уже запущен');
        return;
    }
    window._pornolab_transmission_loaded = true;

    console.log('=== Скрипт Pornolab.net Transmission Uploader запущен ===');

    // Конфигурация Transmission
    const TRANSMISSION_CONFIG = {
        host: '192.168.1.73',
        port: 9092,
        username: 'admin',
        password: 'chuvakadmin',
        downloadDir: '/mnt/HD/HD_a2/Public/Downloads/Test/VR/'
    };

    let sessionId = null;

    // Функция для получения Session ID
    function getSessionId() {
        return new Promise((resolve, reject) => {
            if (sessionId) {
                resolve(sessionId);
                return;
            }

            console.log('🔑 Получение Session ID...');

            const authString = btoa(`${TRANSMISSION_CONFIG.username}:${TRANSMISSION_CONFIG.password}`);
            const url = `http://${TRANSMISSION_CONFIG.host}:${TRANSMISSION_CONFIG.port}/transmission/rpc`;

            GM_xmlhttpRequest({
                method: 'POST',
                url: url,
                headers: {
                    'Authorization': `Basic ${authString}`
                },
                onload: function(response) {
                    if (response.status === 409) {
                        const newSessionId = response.responseHeaders.match(/X-Transmission-Session-Id:\s*([^\s]+)/i);
                        if (newSessionId && newSessionId[1]) {
                            sessionId = newSessionId[1];
                            console.log('✅ Session ID получен:', sessionId);
                            resolve(sessionId);
                        } else {
                            reject(new Error('Не удалось получить Session ID'));
                        }
                    } else if (response.status === 401) {
                        reject(new Error('Ошибка авторизации. Проверьте логин и пароль.'));
                    } else {
                        reject(new Error(`Неожиданный ответ: ${response.status}`));
                    }
                },
                onerror: function(error) {
                    reject(new Error('Ошибка подключения к Transmission'));
                },
                ontimeout: function() {
                    reject(new Error('Таймаут подключения'));
                },
                timeout: 10000
            });
        });
    }

    // Функция для выполнения RPC запроса
    function transmissionRpc(method, args = {}) {
        return new Promise((resolve, reject) => {
            const data = {
                method: method,
                arguments: args
            };

            const authString = btoa(`${TRANSMISSION_CONFIG.username}:${TRANSMISSION_CONFIG.password}`);
            const url = `http://${TRANSMISSION_CONFIG.host}:${TRANSMISSION_CONFIG.port}/transmission/rpc`;

            const headers = {
                'Content-Type': 'application/json',
                'Authorization': `Basic ${authString}`
            };

            if (sessionId) {
                headers['X-Transmission-Session-Id'] = sessionId;
            }

            GM_xmlhttpRequest({
                method: 'POST',
                url: url,
                headers: headers,
                data: JSON.stringify(data),
                onload: function(response) {
                    try {
                        if (response.status === 409) {
                            const newSessionId = response.responseHeaders.match(/X-Transmission-Session-Id:\s*([^\s]+)/i);
                            if (newSessionId && newSessionId[1]) {
                                sessionId = newSessionId[1];
                                console.log('🔄 Session ID обновлен');

                                const newHeaders = {
                                    'Content-Type': 'application/json',
                                    'Authorization': `Basic ${authString}`,
                                    'X-Transmission-Session-Id': sessionId
                                };

                                GM_xmlhttpRequest({
                                    method: 'POST',
                                    url: url,
                                    headers: newHeaders,
                                    data: JSON.stringify(data),
                                    onload: function(retryResponse) {
                                        try {
                                            const result = JSON.parse(retryResponse.responseText);
                                            if (result.result === 'success') {
                                                resolve(result);
                                            } else {
                                                reject(new Error(`Transmission error: ${result.result}`));
                                            }
                                        } catch (e) {
                                            reject(new Error('Ошибка обработки ответа'));
                                        }
                                    },
                                    onerror: function() {
                                        reject(new Error('Ошибка повторного запроса'));
                                    }
                                });
                            } else {
                                reject(new Error('Не удалось обновить Session ID'));
                            }
                            return;
                        }

                        if (response.status === 401) {
                            reject(new Error('Ошибка авторизации в Transmission'));
                            return;
                        }

                        if (response.status !== 200) {
                            reject(new Error(`HTTP ${response.status}`));
                            return;
                        }

                        const result = JSON.parse(response.responseText);
                        if (result.result === 'success') {
                            resolve(result);
                        } else {
                            reject(new Error(`Transmission error: ${result.result}`));
                        }
                    } catch (e) {
                        console.error('❌ Ошибка:', e);
                        reject(new Error('Ошибка обработки ответа от Transmission'));
                    }
                },
                onerror: function(error) {
                    reject(new Error('Ошибка сети при подключении к Transmission'));
                },
                ontimeout: function() {
                    reject(new Error('Таймаут при подключении к Transmission'));
                },
                timeout: 30000
            });
        });
    }

    // Функция для получения списка торрентов в папке (УЛУЧШЕННАЯ)
    async function getTorrentsInFolder(downloadDir) {
        try {
            if (!sessionId) {
                await getSessionId();
            }

            const result = await transmissionRpc('torrent-get', {
                fields: ['id', 'name', 'hashString', 'downloadDir', 'addedDate', 'totalSize', 'status', 'labels', 'error']
            });

            if (!result.arguments || !result.arguments.torrents) {
                return [];
            }

            // Нормализуем целевой путь (убираем лишние слеши в конце)
            const normalizedTargetDir = downloadDir.replace(/\/+$/, '');
            console.log('📂 Целевая папка (нормализованная):', normalizedTargetDir);
            console.log('📋 Всего торрентов в Transmission:', result.arguments.torrents.length);

            // Выводим все пути для отладки
            console.log('📂 Пути всех торрентов:');
            result.arguments.torrents.forEach(t => {
                console.log(`  - ${t.name || 'Без названия'}: ${t.downloadDir || 'Нет пути'}`);
            });

            // Фильтруем торренты по папке загрузки (более гибкая проверка)
            const torrents = result.arguments.torrents.filter(t => {
                if (!t.downloadDir) return false;

                // Нормализуем путь торрента
                const normalizedTorrentDir = t.downloadDir.replace(/\/+$/, '');

                // Проверяем совпадение путей (игнорируем регистр и слеши в конце)
                const matches = normalizedTorrentDir.toLowerCase() === normalizedTargetDir.toLowerCase() ||
                               normalizedTorrentDir.toLowerCase().includes(normalizedTargetDir.toLowerCase()) ||
                               normalizedTargetDir.toLowerCase().includes(normalizedTorrentDir.toLowerCase());

                if (matches) {
                    console.log(`  ✅ НАЙДЕН: ${t.name || 'Без названия'} (${t.downloadDir})`);
                }
                return matches;
            });

            // Сортируем по дате добавления (старые сначала)
            torrents.sort((a, b) => (a.addedDate || 0) - (b.addedDate || 0));

            console.log(`📊 Найдено ${torrents.length} торрентов в папке`);

            // Если торрентов мало, возможно путь отличается - пробуем найти все с похожим путем
            if (torrents.length < 3) {
                console.log('🔍 Мало торрентов найдено, пробуем расширенный поиск...');
                // Ищем все торренты, у которых путь содержит 'VR' или 'Test/VR'
                const allTorrents = result.arguments.torrents.filter(t => {
                    if (!t.downloadDir) return false;
                    return t.downloadDir.includes('VR') || t.downloadDir.includes('Test/VR');
                });

                if (allTorrents.length > torrents.length) {
                    console.log(`📊 Расширенный поиск: найдено ${allTorrents.length} торрентов`);
                    allTorrents.sort((a, b) => (a.addedDate || 0) - (b.addedDate || 0));
                    return allTorrents;
                }
            }

            return torrents;
        } catch (error) {
            console.error('❌ Ошибка получения списка торрентов:', error);
            throw error;
        }
    }

    // Функция для удаления торрента с файлами
    async function deleteTorrentWithFiles(torrentId) {
        try {
            if (!sessionId) {
                await getSessionId();
            }

            const result = await transmissionRpc('torrent-remove', {
                ids: [torrentId],
                'delete-local-data': true
            });

            console.log(`✅ Торрент ${torrentId} удален с файлами`);
            return result;
        } catch (error) {
            console.error('❌ Ошибка удаления торрента:', error);
            throw error;
        }
    }

    // Функция для удаления старых торрентов
    async function deleteOldTorrents(count = 5) {
        try {
            console.log(`🗑️ Удаление ${count} старых торрентов...`);

            const torrents = await getTorrentsInFolder(TRANSMISSION_CONFIG.downloadDir);

            if (torrents.length === 0) {
                console.log('ℹ️ Нет торрентов в папке для удаления');
                return { success: false, message: 'Нет торрентов в папке для удаления' };
            }

            // Берем первые N (самые старые)
            const toDelete = torrents.slice(0, Math.min(count, torrents.length));

            console.log(`📋 Найдено ${torrents.length} торрентов, удаляем ${toDelete.length} старых:`);
            toDelete.forEach(t => {
                console.log(`  - ${t.name || 'Без названия'} (добавлен: ${t.addedDate ? new Date(t.addedDate * 1000).toLocaleDateString() : 'неизвестно'})`);
            });

            // Удаляем каждый торрент
            let deletedCount = 0;
            for (const torrent of toDelete) {
                try {
                    await deleteTorrentWithFiles(torrent.id);
                    deletedCount++;
                } catch (e) {
                    console.error(`⚠️ Ошибка удаления торрента ${torrent.id}:`, e);
                }
            }

            const message = `✅ Удалено ${deletedCount} из ${toDelete.length} старых торрентов из папки VR`;
            console.log(message);

            return {
                success: true,
                message: message,
                deleted: deletedCount,
                total: torrents.length
            };
        } catch (error) {
            console.error('❌ Ошибка удаления старых торрентов:', error);
            return {
                success: false,
                message: `❌ Ошибка: ${error.message}`
            };
        }
    }

    // Функция для получения свободного места
    async function getFreeSpace() {
        try {
            console.log('📊 Проверка свободного места...');

            if (!sessionId) {
                await getSessionId();
            }

            const result = await transmissionRpc('session-get');

            if (result.arguments && result.arguments['download-dir-free-space'] !== undefined) {
                const freeSpace = result.arguments['download-dir-free-space'];
                const freeSpaceGB = freeSpace / 1024 / 1024 / 1024;
                console.log(`📊 Свободно: ${freeSpaceGB.toFixed(2)} Гб`);
                return freeSpace;
            }

            return null;
        } catch (error) {
            console.warn('⚠️ Ошибка получения свободного места:', error.message);
            return null;
        }
    }

    // Функция для добавления торрента
    async function addTorrentToTransmission(torrentData, torrentName, title, torrentUrl) {
        console.log('📤 Добавление торрента в Transmission...');

        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = async function(event) {
                try {
                    const base64Data = event.target.result.split(',')[1];

                    if (!sessionId) {
                        await getSessionId();
                    }

                    const args = {
                        'metainfo': base64Data,
                        'download-dir': TRANSMISSION_CONFIG.downloadDir,
                        'paused': false,
                        'labels': [torrentUrl || torrentName]
                    };

                    if (title) {
                        args['name'] = title;
                    }

                    const result = await transmissionRpc('torrent-add', args);

                    if (result.arguments && result.arguments['torrent-added']) {
                        const hash = result.arguments['torrent-added'].hashString;
                        console.log(`✅ Торрент добавлен! Hash: ${hash}`);
                        resolve({
                            success: true,
                            hash: hash,
                            message: 'Торрент успешно добавлен в Transmission'
                        });
                    } else if (result.arguments && result.arguments['torrent-duplicate']) {
                        const hash = result.arguments['torrent-duplicate'].hashString;
                        console.log(`⚠️ Торрент уже существует! Hash: ${hash}`);
                        resolve({
                            success: true,
                            hash: hash,
                            message: 'Торрент уже существует в Transmission',
                            duplicate: true
                        });
                    } else {
                        reject(new Error('Не удалось добавить торрент'));
                    }
                } catch (error) {
                    reject(error);
                }
            };

            reader.onerror = function() {
                reject(new Error('Ошибка чтения торрент-файла'));
            };

            reader.readAsDataURL(torrentData);
        });
    }

    // Функция для получения данных раздачи
    function getTorrentData() {
        const torrentId = new URLSearchParams(window.location.search).get('t');

        let title = '';
        const h1Title = document.querySelector('#topic-title');
        if (h1Title) {
            title = h1Title.textContent.trim().replace(/\[.*?\]/g, '').trim();
            if (title.length > 100) title = title.substring(0, 100) + '...';
        }

        const downloadLink = document.querySelector('a.dl-stub[href*="dl.php?t="]');
        const downloadUrl = downloadLink ? downloadLink.href : null;

        return { torrentId, title, downloadUrl };
    }

    // Функция для скачивания торрента
    function downloadTorrent(url) {
        return new Promise((resolve, reject) => {
            console.log('📥 Скачивание торрента...');

            GM_xmlhttpRequest({
                method: 'GET',
                url: url,
                responseType: 'blob',
                onload: function(response) {
                    if (response.status === 200) {
                        console.log('📥 Торрент скачан, размер:', response.response.size, 'байт');
                        resolve(response.response);
                    } else {
                        reject(new Error(`HTTP ${response.status}`));
                    }
                },
                onerror: function() {
                    reject(new Error('Ошибка скачивания торрента'));
                },
                ontimeout: function() {
                    reject(new Error('Таймаут скачивания'));
                },
                timeout: 30000
            });
        });
    }

    // Регистрируем команды в меню Tampermonkey
    GM_registerMenuCommand('🧹 Удалить 5 старых торрентов из VR', async function() {
        // Создаем диалог
        const dialog = document.createElement('div');
        dialog.style.cssText = `
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: white;
            padding: 20px 30px;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            z-index: 9999;
            font-size: 14px;
            text-align: center;
            max-width: 400px;
            font-family: Arial, sans-serif;
        `;
        document.body.appendChild(dialog);

        try {
            dialog.innerHTML = '⏳ Проверка торрентов в папке VR...';

            // Получаем список торрентов для отладки
            const allTorrents = await getTorrentsInFolder(TRANSMISSION_CONFIG.downloadDir);

            const result = await deleteOldTorrents(5);

            if (result.success) {
                dialog.innerHTML = `
                    ✅ ${result.message}
                    <br><br>
                    ${result.deleted > 0 ? `Удалено ${result.deleted} торрентов` : 'Нечего удалять'}
                    <br><br>
                    <button onclick="this.parentElement.remove()" style="padding: 5px 20px; cursor: pointer; border-radius: 4px; border: 1px solid #ccc;">OK</button>
                `;
            } else {
                dialog.innerHTML = `
                    ${result.message}
                    <br><br>
                    <button onclick="this.parentElement.remove()" style="padding: 5px 20px; cursor: pointer; border-radius: 4px; border: 1px solid #ccc;">OK</button>
                `;
            }
        } catch (error) {
            dialog.innerHTML = `
                ❌ Ошибка: ${error.message}
                <br><br>
                <button onclick="this.parentElement.remove()" style="padding: 5px 20px; cursor: pointer; border-radius: 4px; border: 1px solid #ccc;">OK</button>
            `;
        }
    });

    GM_registerMenuCommand('📊 Список торрентов в VR', async function() {
        try {
            if (!sessionId) {
                await getSessionId();
            }

            const torrents = await getTorrentsInFolder(TRANSMISSION_CONFIG.downloadDir);

            let message = `📊 Найдено ${torrents.length} торрентов в папке VR\n\n`;
            message += `Папка: ${TRANSMISSION_CONFIG.downloadDir}\n`;
            message += `${'─'.repeat(50)}\n\n`;

            if (torrents.length === 0) {
                message += 'ℹ️ Нет активных торрентов в папке VR\n';
                message += '\n💡 Проверьте, что торренты добавлены в папку:\n';
                message += `   ${TRANSMISSION_CONFIG.downloadDir}`;
            } else {
                torrents.forEach((t, i) => {
                    const date = t.addedDate ? new Date(t.addedDate * 1000).toLocaleString() : 'неизвестно';
                    const size = t.totalSize ? (t.totalSize / 1024 / 1024 / 1024).toFixed(2) + ' Гб' : 'неизвестно';
                    const statuses = ['Остановлен', 'Загружается', 'Скачивается', 'Сидирует'];
                    const status = statuses[t.status] || t.status;
                    const path = t.downloadDir || 'Нет пути';

                    message += `${i+1}. ${t.name || 'Без названия'}\n`;
                    message += `   📅 ${date}\n`;
                    message += `   📦 ${size} | ${status}\n`;
                    message += `   📂 ${path}\n`;
                    message += `   🔗 ${t.hashString || 'N/A'}\n\n`;
                });
            }

            // Создаем диалог для отображения
            const dialog = document.createElement('div');
            dialog.style.cssText = `
                position: fixed;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: white;
                padding: 20px 30px;
                border-radius: 8px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.3);
                z-index: 9999;
                max-width: 600px;
                max-height: 80vh;
                overflow-y: auto;
                font-family: monospace;
                font-size: 12px;
                white-space: pre-wrap;
                word-wrap: break-word;
            `;

            dialog.innerHTML = `
                <div style="font-family: Arial, sans-serif; margin-bottom: 10px; font-size: 14px;">
                    <strong>${message.split('\n')[0]}</strong>
                </div>
                <div style="font-family: monospace; font-size: 12px; line-height: 1.6;">
                    ${message.split('\n').slice(1).join('\n')}
                </div>
                <br>
                <button onclick="this.parentElement.remove()" style="padding: 5px 20px; cursor: pointer; border-radius: 4px; border: 1px solid #ccc; font-family: Arial, sans-serif;">Закрыть</button>
            `;

            document.body.appendChild(dialog);
        } catch (error) {
            alert(`❌ Ошибка: ${error.message}`);
        }
    });

    // Основная функция добавления кнопки
    function addUploadButton() {
        console.log('🔍 Поиск места для кнопки...');

        if (document.getElementById('rutracker-upload-container')) {
            console.log('⚠️ Кнопка уже существует');
            return;
        }

        const fileListBtn = document.getElementById('tor-filelist-btn');
        if (!fileListBtn) {
            console.log('⏳ Кнопка "Список файлов" не найдена');
            return;
        }

        const data = getTorrentData();
        if (!data.torrentId || !data.downloadUrl) {
            console.log('❌ Не удалось получить данные раздачи');
            return;
        }

        console.log('📋 Данные раздачи:');
        console.log('  ID:', data.torrentId);
        console.log('  Title:', data.title);
        console.log('  URL:', data.downloadUrl);

        const fileListP = fileListBtn.closest('p');
        if (!fileListP) {
            console.log('❌ Не найден <p> с кнопкой');
            return;
        }

        const parentTd = fileListP.closest('td');
        if (!parentTd) {
            console.log('❌ Не найден <td>');
            return;
        }

        const buttonContainer = document.createElement('div');
        buttonContainer.id = 'rutracker-upload-container';
        buttonContainer.style.cssText = 'padding-top: 8px; text-align: center;';

        const uploadButton = document.createElement('input');
        uploadButton.id = 'rutracker-upload-button';
        uploadButton.type = 'button';
        uploadButton.className = 'lite';
        uploadButton.style.cssText = 'width: 120px; cursor: pointer;';
        uploadButton.value = '📤 Отправить';

        const statusDiv = document.createElement('div');
        statusDiv.id = 'rutracker-upload-status';
        statusDiv.style.cssText = `
            margin-top: 5px;
            font-size: 12px;
            transition: opacity 0.5s ease;
            display: none;
            padding: 3px 8px;
            border-radius: 3px;
            max-width: 200px;
            margin-left: auto;
            margin-right: auto;
            box-sizing: border-box;
            word-wrap: break-word;
        `;

        buttonContainer.appendChild(uploadButton);
        buttonContainer.appendChild(statusDiv);

        parentTd.insertBefore(buttonContainer, fileListP.nextSibling);

        console.log('✅ Кнопка добавлена внутри <td> под "Список файлов"');

        // Проверяем свободное место
        (async function() {
            try {
                const freeSpace = await getFreeSpace();
                if (freeSpace !== null) {
                    const freeSpaceGB = freeSpace / 1024 / 1024 / 1024;
                    statusDiv.style.display = 'block';
                    statusDiv.style.opacity = '1';
                    statusDiv.innerHTML = `💾 Свободно: ${freeSpaceGB.toFixed(2)} Гб`;
                    statusDiv.style.color = '#155724';
                    statusDiv.style.background = '#d4edda';

                    setTimeout(() => {
                        statusDiv.style.opacity = '0';
                        setTimeout(() => {
                            statusDiv.style.display = 'none';
                            statusDiv.style.opacity = '1';
                        }, 500);
                    }, 5000);
                }
            } catch (e) {
                console.warn('⚠️ Ошибка проверки места:', e);
            }
        })();

        // Обработчик клика
        uploadButton.addEventListener('click', async function() {
            const statusDiv = document.getElementById('rutracker-upload-status');

            statusDiv.style.display = 'block';
            statusDiv.style.opacity = '1';

            uploadButton.disabled = true;
            uploadButton.value = '⏳ Загрузка...';

            try {
                statusDiv.innerHTML = '⏳ Проверка свободного места...';
                statusDiv.style.color = '#333';
                statusDiv.style.background = '#fff3cd';

                const freeSpace = await getFreeSpace();

                if (freeSpace !== null) {
                    const freeSpaceGB = freeSpace / 1024 / 1024 / 1024;
                    const MIN_FREE_SPACE = 5 * 1024 * 1024 * 1024;

                    if (freeSpace < MIN_FREE_SPACE) {
                        throw new Error(`Недостаточно места! Свободно: ${freeSpaceGB.toFixed(2)} Гб, нужно минимум 5 Гб`);
                    }

                    statusDiv.innerHTML = `💾 Свободно: ${freeSpaceGB.toFixed(2)} Гб`;
                    statusDiv.style.color = '#155724';
                    statusDiv.style.background = '#d4edda';

                    await new Promise(resolve => setTimeout(resolve, 800));
                }

                statusDiv.innerHTML = '⏳ Скачивание торрента...';
                statusDiv.style.color = '#333';
                statusDiv.style.background = '#cce5ff';

                const blob = await downloadTorrent(data.downloadUrl);
                console.log('✅ Торрент скачан, размер:', blob.size);

                statusDiv.innerHTML = '⏳ Отправка в Transmission...';
                statusDiv.style.background = '#cce5ff';

                const torrentName = `[pornolab.net]t${data.torrentId}.torrent`;
                const result = await addTorrentToTransmission(blob, torrentName, data.title, data.downloadUrl);

                let message = '✅ Торрент успешно добавлен в Transmission!';
                let bgColor = '#d4edda';
                let textColor = '#155724';

                if (result.duplicate) {
                    message = '⚠️ Торрент уже существует в Transmission';
                    bgColor = '#fff3cd';
                    textColor = '#856404';
                }

                statusDiv.innerHTML = message;
                statusDiv.style.color = textColor;
                statusDiv.style.background = bgColor;

                console.log('✅ Успешно!', result);

            } catch (error) {
                console.error('❌ Ошибка:', error);

                let errorMessage = error.message || 'Неизвестная ошибка';
                if (errorMessage.includes('401')) {
                    errorMessage = '❌ Ошибка авторизации в Transmission';
                } else if (errorMessage.includes('ECONNREFUSED')) {
                    errorMessage = '❌ Не удалось подключиться к Transmission';
                } else if (errorMessage.includes('недостаточно')) {
                    errorMessage = '❌ ' + errorMessage;
                }

                statusDiv.innerHTML = errorMessage;
                statusDiv.style.color = '#721c24';
                statusDiv.style.background = '#f8d7da';
            } finally {
                uploadButton.disabled = false;
                uploadButton.value = '📤 Отправить';

                setTimeout(() => {
                    statusDiv.style.opacity = '0';
                    setTimeout(() => {
                        statusDiv.style.display = 'none';
                        statusDiv.style.opacity = '1';
                    }, 500);
                }, 5000);
            }
        });
    }

    // Инициализация
    function init() {
        console.log('🚀 Инициализация...');
        console.log('📌 Доступны команды в меню Tampermonkey:');
        console.log('   🧹 Удалить 5 старых торрентов из VR');
        console.log('   📊 Список торрентов в VR');

        // Удаляем старые кнопки
        const oldContainers = document.querySelectorAll('#rutracker-upload-container');
        oldContainers.forEach(el => el.remove());

        let attempts = 0;
        const maxAttempts = 20;

        const checkInterval = setInterval(() => {
            attempts++;
            const fileListBtn = document.getElementById('tor-filelist-btn');

            if (fileListBtn) {
                clearInterval(checkInterval);
                console.log('✅ Кнопка "Список файлов" найдена');
                addUploadButton();
            } else if (attempts >= maxAttempts) {
                clearInterval(checkInterval);
                console.log('⚠️ Кнопка "Список файлов" не найдена, пробуем добавить вручную');
                addUploadButton();
            }
        }, 500);
    }

    // Запускаем
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

})();
